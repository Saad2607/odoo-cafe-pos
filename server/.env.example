SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional (defaults work for Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=Brivio Cafe <your@gmail.com>

SEED_ADMIN_NAME="Cafe Admin"
