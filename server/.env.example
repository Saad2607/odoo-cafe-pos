DATABASE_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/odoo-cafe
USE_MEMORY_MONGO=false
JWT_SECRET=your-secret-here
PORT=3001
